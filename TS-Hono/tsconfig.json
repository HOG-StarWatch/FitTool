{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types", "@types/node"],
    "declaration": true,
    "sourceMap": false,
    "baseUrl": "."
  },
  "include": ["src/**/*", "server.ts", "build.pages.ts"],
  "exclude": ["node_modules", "dist", "dist-workers"]
}
